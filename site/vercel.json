{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "cod-stats-one.vercel.app"
        }
      ],
      "destination": "https://mapfive.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/r",
      "destination": "/api/r"
    },
    {
      "source": "/g",
      "destination": "/api/g"
    },
    {
      "source": "/c",
      "destination": "/api/c"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/goat-builder.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
